# Supabase project settings (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, NEVER expose to the client. Used by
# Route Handlers and scripts/seed-products.ts to bypass RLS intentionally.
SUPABASE_SERVICE_ROLE_KEY=

# Used for auth email redirect links and the Razorpay receipt/webhook flow.
# Local dev: http://localhost:3000. Production: your real domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Razorpay (Settings -> API Keys). Use TEST mode keys until you're ready to go live.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Settings -> Webhooks -> your webhook's secret (separate from the API key secret)
RAZORPAY_WEBHOOK_SECRET=
